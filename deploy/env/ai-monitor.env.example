## AI Monitor configuration (SiliconFlow VLM + Tinybird)
##
## How to use:
##   set -a
##   source deploy/env/ai-monitor.env.example
##   set +a
##   go run ./cmd/server
##
## Requirements:
## - SiliconFlow API key from https://cloud.siliconflow.com/account/ak
## - Tinybird admin token (for Events API ingestion)
## - S3 bucket must be configured for alert clip storage
## - NEXTAUTH_SECRET must match the Suvidhi auth secret

# ──── Shared auth with Suvidhi ────
NEXTAUTH_SECRET="replace-with-the-same-secret-used-by-suvidhi"
AUTH_COOKIE_SECURE="false"
SIGNING_SECRET="replace-with-a-long-random-secret-for-media-signing"

# ──── SiliconFlow VLM ────
SILICONFLOW_API_KEY="replace-with-your-siliconflow-api-key"
# Model to use (default: Qwen/Qwen3-VL-32B-Instruct)
# SILICONFLOW_MODEL="Qwen/Qwen3-VL-32B-Instruct"

# ──── Tinybird ────
TINYBIRD_ADMIN_TOKEN="replace-with-your-tinybird-admin-token"
# Base URL (default: https://api.eu-central-1.aws.tinybird.co)
# TINYBIRD_BASE_URL="https://api.eu-central-1.aws.tinybird.co"
# Data source name (default: camera_ai_analysis)
TINYBIRD_AI_DATASOURCE="camera_ai_analysis"

# ──── AI Monitor Settings ────
# Snapshot interval in seconds (default: 60, min: 10, max: 600)
AI_SNAPSHOT_INTERVAL_SECONDS="60"
# Alert cooldown in seconds - skip analysis after alert, record clip instead
# (default: 300 = 5 minutes, min: 60, max: 1800)
AI_ALERT_COOLDOWN_SECONDS="300"

# ──── Logging ────
# Log file path (default: ./logs/camera-ai.log, or $PERSIST_DIR/logs/camera-ai.log)
# Set to "none" to disable file logging (stderr only)
# LOG_FILE="./logs/camera-ai.log"
# LOG_DIR="./logs"

# ──── S3 (required for alert clip storage) ────
S3_BUCKET="replace-with-your-camera-ai-bucket"
S3_REGION="ap-south-1"
S3_SSE="AES256"
S3_UPLOAD_INTERVAL_SECONDS="2"
S3_DELETE_LOCAL_SEGMENTS="true"
S3_DELETE_LOCAL_SESSION_ON_COMPLETE="true"
