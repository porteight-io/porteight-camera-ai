## S3-only recordings (local dev) example
##
## How to use:
##   set -a
##   source deploy/env/s3-only.local.env.example
##   set +a
##   go run ./cmd/server
##
## Requirements:
## - Your local AWS credentials must be configured (aws configure / AWS_PROFILE / SSO)
## - Bucket is private; service uploads to recordings/<key>/<session>/...
## - NEXTAUTH_SECRET must match the Suvidhi auth secret

NEXTAUTH_SECRET="replace-with-the-same-secret-used-by-suvidhi"
AUTH_COOKIE_SECURE="false"
SIGNING_SECRET="replace-with-a-long-random-secret-for-media-signing"

# Super admin credentials for the camera-ai webserver login page.
# These seed the admin user on first boot (only if no users exist in the DB).
# To change the password after first boot, delete camera_ai.db and restart.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-strong-password"

# Secret used to sign admin session cookies.
# Defaults to NEXTAUTH_SECRET + "-camera-admin-session" if not set.
# Set to a unique random value in production.
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret-for-admin-sessions"

S3_BUCKET="your-dedicated-bucket"
S3_REGION="ap-south-1"

# Encryption at rest (recommended)
S3_SSE="AES256"          # or "aws:kms"
# S3_KMS_KEY_ID="..."    # if using aws:kms

# Upload cadence (seconds)
S3_UPLOAD_INTERVAL_SECONDS="2"

# "S3-only" behavior:
# - after each segment is uploaded successfully, delete the local .ts segment file
S3_DELETE_LOCAL_SEGMENTS="true"
# - after the stream ends and final sync completes, delete the whole local session folder
S3_DELETE_LOCAL_SESSION_ON_COMPLETE="true"

